    <title>R U I DO ::: [atrapasueños]</title>
    <style>
        body {
            /* FONDO SHOEGAZE TILEADO: Textura borrosa y ruidosa */
            background-color: #0000D1;
            background-image: url('https://blob.gifcities.org/gifcities/IJGPBQ2P6OB4AVELWZ57ZQNL4R56CTPF.gif'); /* Textura estática púrpura/negra */
            background-repeat: repeat;
            
            /* Colores de texto Shoegaze: Lavanda y Gris difuminado */
            color: #D68FFF;
            font-family: "Helvetica", Times, serif; /* O Courier */
            cursor: crosshair; /* Cursor retro */
            margin: 0;
            padding: 10px;
        }

        /* Contenedor principal estilo tabla GeoCities pero descentrado */
        .feedback-container {
            width: 85%;
            margin: 30px auto;
            border: 6px outset #4b0082; /* Borde Indigo 3D */
            background-color: rgba(0, 0, 0, 0.8); /* Fondo negro semi-transparente para legibilidad */
            padding: 15px;
            box-shadow: 10px 10px 0px #330033; /* Sombra sólida retro */
        }

        h1 {
            /* Título borroso Shoegaze */
            color: #ffb3ff;
            text-align: center;
            font-size: 45px;
            font-family: "Courier New", Courier, monospace;
            text-transform: uppercase;
            letter-spacing: 5px;
            text-shadow: 0 0 10px #ff00ff, 0 0 20px #ff00ff; /* Efecto brillo/blur */
        }

        h2, h3 {
            color: #99FFFF; /* Cian eléctrico para contraste */
            font-family: sans-serif;
            text-decoration: underline;
        }

        /* El clásico BLINK noventero */
        @keyframes blinker {
            50% { opacity: 0; }
        }
        .blink {
            animation: blinker 1s linear infinite;
            color: #ff0055; /* Rojo neón */
            font-weight: bold;
        }

        /* Botones de navegación estilo "píxel" */
        .nav-link {
            border: 2px solid #d1b3ff;
            padding: 5px 10px;
            color: #d1b3ff;
            text-decoration: none;
            display: inline-block;
            margin: 5px;
            background-color: #330033;
        }
        .nav-link:hover {
            background-color: #ff00ff;
            color: #000;
        }

        /* Marquee Shoegaze: lento y atmosférico */
        .vibe-marquee {
            background-color: #4b0082;
            color: #fff;
            padding: 3px;
            border-top: 2px solid #ffb3ff;
            border-bottom: 2px solid #ffb3ff;
        }

        /* Contenedor de links de plataformas (más feo, más GeoCities) */
        .noise-box {
            border: 3px dashed #99FFFF;
            padding: 15px;
            margin: 20px;
            text-align: center;
        }

        .platform-icon {
            margin: 10px;
            filter: grayscale(100%) contrast(150%); /* Efecto foto borrosa */
            transition: 0.3s;
        }
        .platform-icon:hover {
            filter: none; /* Recupera color al hover */
        }

    </style>
</head>
